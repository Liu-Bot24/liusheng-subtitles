# 浮光译影本机服务配置。
# 预加载字幕的 ASR 与翻译模型优先在插件侧边栏配置。
# 这里主要保留给开发调试，或不通过插件直接调用 Helper 的场景。

# FUGUANG_ASR_PROVIDER_TYPE=openai
# FUGUANG_ASR_MODEL=base

# FUGUANG_ASR_PROVIDER_TYPE=openai
# FUGUANG_ASR_BASE_URL=https://api.openai.com/v1
# FUGUANG_ASR_MODEL=whisper-1
# FUGUANG_ASR_API_KEY=

# FUGUANG_ASR_PROVIDER_TYPE=groq
# FUGUANG_ASR_BASE_URL=https://api.groq.com/openai/v1
# FUGUANG_ASR_MODEL=whisper-large-v3-turbo
# FUGUANG_ASR_API_KEY=

# FUGUANG_ASR_PROVIDER_TYPE=xai
# FUGUANG_ASR_BASE_URL=https://api.x.ai/v1
# FUGUANG_ASR_MODEL=grok-2-voice-1212
# FUGUANG_ASR_API_KEY=

# FUGUANG_LLM_PROVIDER_TYPE=openai
# FUGUANG_LLM_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
# FUGUANG_LLM_MODEL=mimo-v2.5-pro
# FUGUANG_LLM_API_KEY=

# FUGUANG_LLM_PROVIDER_TYPE=openai
# FUGUANG_LLM_BASE_URL=https://api.siliconflow.cn/v1
# FUGUANG_LLM_MODEL=deepseek-ai/DeepSeek-V3.2
# FUGUANG_LLM_API_KEY=

FUGUANG_TARGET_LANGUAGE=zh-CN
FUGUANG_ASR_WORKERS=1
FUGUANG_TRANSLATION_WORKERS=3
