{
  "manifest_version": 3,
  "name": "流声字幕 - 基于 ASR 与大语言模型的流媒体影视、动漫生肉视频字幕生成与翻译",
  "short_name": "流声字幕",
  "description": "基于 ASR 与大语言模型，为流媒体影视、动漫生肉视频生成字幕并翻译。",
  "version": "0.1.2",
  "action": {
    "default_title": "流声字幕"
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "alarms",
    "offscreen",
    "declarativeNetRequestWithHostAccess",
    "sidePanel",
    "scripting",
    "storage",
    "webNavigation",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "src/content/subtitle-overlay.js",
        "src/content/media-bridge.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "src/content/page-sniffer.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; frame-src 'self'; worker-src 'self'; connect-src 'self' https://* http://*:*"
  }
}
